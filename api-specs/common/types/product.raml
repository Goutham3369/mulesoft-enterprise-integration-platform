#%RAML 1.0 Library

usage: Product-related data types for the enterprise integration platform

types:
  ProductCategory:
    type: object
    description: Hierarchical product category classification
    properties:
      categoryId:
        type: string
        description: Unique identifier for the category
        example: "CAT-ELECTRONICS-001"
      categoryName:
        type: string
        description: Display name of the category
        maxLength: 200
        example: "Industrial Electronics"
      parentCategoryId?:
        type: string
        description: Parent category ID for hierarchical classification
        example: "CAT-ELECTRONICS"
      categoryPath:
        type: string
        description: Full category path from root to this category
        example: "Electronics > Industrial Electronics"
      isActive:
        type: boolean
        description: Whether this category is currently active
        default: true
        example: true
      sortOrder?:
        type: integer
        description: Display sort order within parent category
        minimum: 0
        example: 10

  PricingInfo:
    type: object
    description: Pricing details for a product including tiered and promotional pricing
    properties:
      listPrice:
        type: number
        format: double
        description: Standard list price
        minimum: 0
        example: 299.99
      costPrice:
        type: number
        format: double
        description: Cost price from supplier
        minimum: 0
        example: 150.00
      wholesalePrice?:
        type: number
        format: double
        description: Wholesale price for B2B customers
        minimum: 0
        example: 225.00
      promotionalPrice?:
        type: number
        format: double
        description: Current promotional price if a promotion is active
        minimum: 0
        example: 249.99
      promotionStartDate?:
        type: date-only
        description: Start date of the promotional pricing
        example: "2024-01-01"
      promotionEndDate?:
        type: date-only
        description: End date of the promotional pricing
        example: "2024-03-31"
      currency:
        type: string
        description: ISO 4217 currency code
        pattern: "^[A-Z]{3}$"
        default: "USD"
        example: "USD"
      taxClass:
        type: string
        description: Tax classification for this product
        enum: [STANDARD, REDUCED, ZERO, EXEMPT]
        default: "STANDARD"
        example: "STANDARD"
      marginPercent?:
        type: number
        format: double
        description: Calculated margin percentage
        example: 49.97
      priceTiers?:
        type: PriceTier[]
        description: Volume-based pricing tiers

  PriceTier:
    type: object
    description: Volume-based pricing tier
    properties:
      minQuantity:
        type: integer
        description: Minimum quantity for this tier
        minimum: 1
        example: 100
      maxQuantity?:
        type: integer
        description: Maximum quantity for this tier (null means unlimited)
        example: 499
      unitPrice:
        type: number
        format: double
        description: Unit price for this quantity tier
        minimum: 0
        example: 259.99

  InventoryLevel:
    type: object
    description: Current inventory levels across warehouses
    properties:
      productId:
        type: string
        description: Product identifier
        example: "PROD-SKU-78432"
      sku:
        type: string
        description: Stock keeping unit
        example: "WDG-PRO-X500-BLK"
      totalOnHand:
        type: integer
        description: Total quantity on hand across all warehouses
        minimum: 0
        example: 1250
      totalReserved:
        type: integer
        description: Total quantity reserved for pending orders
        minimum: 0
        example: 87
      totalAvailable:
        type: integer
        description: Total available quantity (onHand - reserved)
        minimum: 0
        example: 1163
      reorderPoint:
        type: integer
        description: Quantity threshold that triggers reorder
        minimum: 0
        example: 200
      reorderQuantity:
        type: integer
        description: Quantity to order when reorder point is reached
        minimum: 0
        example: 500
      isBackorderable:
        type: boolean
        description: Whether this product can be backordered
        default: false
        example: true
      leadTimeDays:
        type: integer
        description: Supplier lead time in days
        minimum: 0
        example: 14
      warehouseBreakdown?:
        type: WarehouseStock[]
        description: Inventory breakdown by warehouse
      lastStockCheckDate?:
        type: datetime
        description: Last physical stock check date
        example: "2024-01-10T08:00:00.000Z"

  WarehouseStock:
    type: object
    description: Stock level at a specific warehouse
    properties:
      warehouseId:
        type: string
        description: Warehouse identifier
        example: "WH-EAST-001"
      warehouseName:
        type: string
        description: Warehouse display name
        example: "East Coast Distribution Center"
      quantityOnHand:
        type: integer
        minimum: 0
        example: 450
      quantityReserved:
        type: integer
        minimum: 0
        example: 30
      quantityAvailable:
        type: integer
        minimum: 0
        example: 420
      binLocation?:
        type: string
        description: Physical bin/shelf location within the warehouse
        example: "A-12-3-B"

  Product:
    type: object
    description: Complete product record from the unified product catalog
    properties:
      productId:
        type: string
        description: Globally unique product identifier
        example: "PROD-SKU-78432"
      sku:
        type: string
        description: Stock keeping unit
        maxLength: 50
        example: "WDG-PRO-X500-BLK"
      name:
        type: string
        description: Product display name
        maxLength: 300
        example: "Enterprise Widget Pro X500"
      description:
        type: string
        description: Full product description
        maxLength: 5000
        example: "High-performance enterprise widget with advanced connectivity features and industrial-grade durability."
      shortDescription?:
        type: string
        description: Short description for listings
        maxLength: 500
        example: "Enterprise-grade widget with advanced connectivity"
      brand:
        type: string
        description: Product brand name
        maxLength: 200
        example: "TechWidgets Inc."
      manufacturer?:
        type: string
        description: Manufacturer name
        maxLength: 200
        example: "Global Manufacturing Corp."
      manufacturerPartNumber?:
        type: string
        description: Manufacturer's part number
        maxLength: 100
        example: "GMP-X500-BLK-V2"
      category:
        type: ProductCategory
      status:
        type: string
        description: Product lifecycle status
        enum: [DRAFT, ACTIVE, DISCONTINUED, OUT_OF_STOCK, COMING_SOON, ARCHIVED]
        example: "ACTIVE"
      pricing:
        type: PricingInfo
      inventory:
        type: InventoryLevel
      weight?:
        type: number
        format: double
        description: Product weight in kilograms
        minimum: 0
        example: 2.5
      dimensions?:
        type: ProductDimensions
      upc?:
        type: string
        description: Universal Product Code
        maxLength: 20
        example: "012345678901"
      ean?:
        type: string
        description: European Article Number
        maxLength: 20
        example: "4006381333931"
      isHazardous:
        type: boolean
        description: Whether the product requires hazardous materials handling
        default: false
        example: false
      isSerialTracked:
        type: boolean
        description: Whether individual units are tracked by serial number
        default: false
        example: true
      isBatchTracked:
        type: boolean
        description: Whether the product is tracked by batch/lot number
        default: false
        example: false
      shelfLifeDays?:
        type: integer
        description: Shelf life in days (for perishable products)
        minimum: 0
      warrantyMonths?:
        type: integer
        description: Warranty period in months
        minimum: 0
        example: 24
      countryOfOrigin?:
        type: string
        description: ISO 3166-1 alpha-2 country code of manufacture
        pattern: "^[A-Z]{2}$"
        example: "DE"
      harmonizedCode?:
        type: string
        description: Harmonized System tariff code
        example: "8471.30.0100"
      sapMaterialNumber?:
        type: string
        description: SAP Material Number
        example: "MAT-000012345"
      imageUrls?:
        type: string[]
        description: Product image URLs
        example: ["https://cdn.example.com/products/x500-front.jpg", "https://cdn.example.com/products/x500-side.jpg"]
      tags?:
        type: string[]
        description: Searchable product tags
        example: ["widget", "enterprise", "industrial", "connectivity"]
      attributes?:
        type: object
        description: Dynamic product attributes as key-value pairs
      createdAt:
        type: datetime
        description: Record creation timestamp
        example: "2023-03-20T12:00:00.000Z"
      updatedAt:
        type: datetime
        description: Record last update timestamp
        example: "2024-01-12T09:15:00.000Z"

  ProductDimensions:
    type: object
    description: Physical dimensions of the product
    properties:
      lengthCm:
        type: number
        format: double
        description: Length in centimeters
        minimum: 0
        example: 30.0
      widthCm:
        type: number
        format: double
        description: Width in centimeters
        minimum: 0
        example: 20.0
      heightCm:
        type: number
        format: double
        description: Height in centimeters
        minimum: 0
        example: 15.0
