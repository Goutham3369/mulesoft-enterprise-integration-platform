#%RAML 1.0 Trait

usage: Apply to collection endpoints that support server-side pagination

queryParameters:
  page:
    type: integer
    description: Page number to retrieve (1-based indexing)
    minimum: 1
    default: 1
    required: false
    example: 1
  size:
    type: integer
    description: Number of items per page
    minimum: 1
    maximum: 100
    default: 20
    required: false
    example: 20
  sortBy:
    type: string
    description: Field name to sort results by
    required: false
    example: "createdAt"
  sortOrder:
    type: string
    description: Sort direction
    enum: [asc, desc]
    default: "desc"
    required: false
    example: "desc"

responses:
  200:
    headers:
      X-Total-Count:
        type: integer
        description: Total number of items matching the query
        example: 293
      X-Page-Number:
        type: integer
        description: Current page number
        example: 1
      X-Page-Size:
        type: integer
        description: Number of items per page
        example: 20
      X-Total-Pages:
        type: integer
        description: Total number of pages
        example: 15
      Link:
        type: string
        description: RFC 5988 link relations for pagination navigation
        required: false
        example: '</api/v1/orders?page=2&size=20>; rel="next", </api/v1/orders?page=15&size=20>; rel="last"'
