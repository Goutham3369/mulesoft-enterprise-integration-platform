<?xml version="1.0" encoding="UTF-8"?>
<mule xmlns="http://www.mulesoft.org/schema/mule/core"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xmlns:http="http://www.mulesoft.org/schema/mule/http"
      xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core"
      xsi:schemaLocation="
        http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
        http://www.mulesoft.org/schema/mule/http http://www.mulesoft.org/schema/mule/http/current/mule-http.xsd
        http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd">

    <!-- ======================== Global Error Handler ======================== -->
    <error-handler name="global-error-handler" doc:name="Global Error Handler">

        <!-- Bad Request - Validation Errors -->
        <on-error-propagate type="VALIDATION:INVALID_VALUE, VALIDATION:BLANK, VALIDATION:NULL, VALIDATION:MISSING"
                            doc:name="Validation Error (400)" enableNotifications="true" logException="true">
            <logger level="WARN" doc:name="Log Validation Error"
                    message="Validation error occurred: #[error.description] | CorrelationId: #[correlationId]" />
            <ee:transform doc:name="Build 400 Response">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    success: false,
    errorCode: "VALIDATION_ERROR",
    httpStatus: 400,
    message: error.description default "Request validation failed",
    details: error.errorMessage.payload default null,
    correlationId: correlationId,
    timestamp: now() as String {format: "yyyy-MM-dd'T'HH:mm:ss.SSSZ"}
}]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">400</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- Not Found -->
        <on-error-propagate type="MULE:EXPRESSION"
                            doc:name="Not Found Error (404)" enableNotifications="true" logException="true"
                            when="#[error.description contains 'not found' or error.description contains 'NOT_FOUND']">
            <logger level="WARN" doc:name="Log Not Found Error"
                    message="Resource not found: #[error.description] | CorrelationId: #[correlationId]" />
            <ee:transform doc:name="Build 404 Response">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    success: false,
    errorCode: "RESOURCE_NOT_FOUND",
    httpStatus: 404,
    message: error.description default "The requested resource was not found",
    correlationId: correlationId,
    timestamp: now() as String {format: "yyyy-MM-dd'T'HH:mm:ss.SSSZ"}
}]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">404</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- Connectivity / Timeout Errors -->
        <on-error-propagate type="HTTP:CONNECTIVITY, HTTP:TIMEOUT, MULE:CONNECTIVITY, HTTP:RETRY_EXHAUSTED"
                            doc:name="Connectivity Error (503)" enableNotifications="true" logException="true">
            <logger level="ERROR" doc:name="Log Connectivity Error"
                    message="Connectivity error: #[error.description] | CorrelationId: #[correlationId]" />
            <ee:transform doc:name="Build 503 Response">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    success: false,
    errorCode: "SERVICE_UNAVAILABLE",
    httpStatus: 503,
    message: "A downstream service is currently unavailable. Please retry later.",
    detail: error.description default "Unknown connectivity issue",
    correlationId: correlationId,
    timestamp: now() as String {format: "yyyy-MM-dd'T'HH:mm:ss.SSSZ"},
    retryAfter: 30
}]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">503</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- Conflict / Duplicate Request -->
        <on-error-propagate type="OS:KEY_ALREADY_EXISTS"
                            doc:name="Conflict Error (409)" enableNotifications="true" logException="true">
            <logger level="WARN" doc:name="Log Conflict Error"
                    message="Duplicate request detected: #[error.description] | CorrelationId: #[correlationId]" />
            <ee:transform doc:name="Build 409 Response">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    success: false,
    errorCode: "CONFLICT",
    httpStatus: 409,
    message: "A duplicate request was detected. This operation has already been processed.",
    correlationId: correlationId,
    timestamp: now() as String {format: "yyyy-MM-dd'T'HH:mm:ss.SSSZ"}
}]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">409</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- JMS / Messaging Errors -->
        <on-error-continue type="JMS:PUBLISHING, JMS:CONSUMING, JMS:CONNECTIVITY"
                           doc:name="JMS Error (handled)" enableNotifications="true" logException="true">
            <logger level="ERROR" doc:name="Log JMS Error"
                    message="JMS messaging error: #[error.description] | CorrelationId: #[correlationId]" />
            <ee:transform doc:name="Build JMS Error Response">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    success: false,
    errorCode: "MESSAGING_ERROR",
    httpStatus: 500,
    message: "An error occurred while processing the message queue operation.",
    detail: error.description default "Unknown JMS error",
    correlationId: correlationId,
    timestamp: now() as String {format: "yyyy-MM-dd'T'HH:mm:ss.SSSZ"}
}]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">500</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-continue>

        <!-- HTTP Bad Request from downstream -->
        <on-error-propagate type="HTTP:BAD_REQUEST"
                            doc:name="Downstream Bad Request (400)" enableNotifications="true" logException="true">
            <logger level="WARN" doc:name="Log Downstream Bad Request"
                    message="Downstream bad request: #[error.description] | CorrelationId: #[correlationId]" />
            <ee:transform doc:name="Build 400 Response">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    success: false,
    errorCode: "DOWNSTREAM_BAD_REQUEST",
    httpStatus: 400,
    message: "A downstream service rejected the request.",
    detail: error.description default "Invalid request to downstream service",
    correlationId: correlationId,
    timestamp: now() as String {format: "yyyy-MM-dd'T'HH:mm:ss.SSSZ"}
}]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">400</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- Catch All - Internal Server Error -->
        <on-error-propagate type="ANY"
                            doc:name="Catch All Error (500)" enableNotifications="true" logException="true">
            <logger level="ERROR" doc:name="Log Unhandled Error"
                    message="Unhandled error: #[error.errorType.identifier] - #[error.description] | CorrelationId: #[correlationId]" />
            <ee:transform doc:name="Build 500 Response">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    success: false,
    errorCode: "INTERNAL_SERVER_ERROR",
    httpStatus: 500,
    message: "An unexpected error occurred while processing your request.",
    detail: error.description default "Unknown internal error",
    errorType: error.errorType.identifier default "UNKNOWN",
    correlationId: correlationId,
    timestamp: now() as String {format: "yyyy-MM-dd'T'HH:mm:ss.SSSZ"}
}]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">500</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>
    </error-handler>

</mule>
